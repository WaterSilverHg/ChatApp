
# =====================================================
# Qt 相关忽略规则
# =====================================================

# Qt 编译生成的文件
*.moc
moc_*.cpp
moc_*.h
*.moc
ui_*.h
qrc_*.cpp
qrc_*.h
*.rcc
*.qmlc
*.jsc


# Qt Creator 相关
*.autosave
*.creator
*.creator.user
*.creator.user.*
*.creator.user.prefs
*.config
*.files
*.includes
CMakeLists.txt.user
CMakeLists.txt.user.*
*.cflags
*.cxxflags
*.config
*.includes
CMakeLists.txt.user
*.pro.user
*.pro.user.*
*.pri.user
*.pri.user.*

# Qt 临时文件
*.pyc
*.pyo
__pycache__/

# Qt 资源编译临时文件
*.rcc

# Qt 单元测试生成文件
tst_*.exe
tst_*.app

# Qt 部署相关
*.app
*.dmg
*.deb
*.rpm
*.snap

# Qt 缓存目录
build-*/
*-build-*
*-deploy-*
*.shadow-build*

# Qt 日志文件
qt_log.log
qt_out.txt

# macOS 下 Qt 相关
*.dSYM/
*.framework/

# Windows 下 Qt 相关
*.windeployqt
*.exe.manifest
*.intermediate.manifest

# Linux 下 Qt 相关
*.so
*.so.*
*.la
*.lo

# Qt Charts 相关
*.qch
*.qhc

# Qt Quick 编译文件
*.qmltypes
*.qmlproject.user
*.qmlproject.user.*

# Qt 可视化表单文件
*.ui